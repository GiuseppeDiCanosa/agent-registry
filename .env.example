# Copia in `.env` (gitignored) e riempi con i tuoi valori. Mai committare `.env`.

# --- home dati della sandbox ---
# Sorgente del volume /data. Vuoto/assente = volume Docker isolato (default).
# Per far notificare ANCHE gli agenti che girano sull'host, punta alla home reale
# (percorso ASSOLUTO, es. /Users/tuo-utente/.agent-registry):
AGENT_REGISTRY_DATA_SOURCE=

# --- git-sync del servizio db ---
# Remote privato della home registry (es. la wiki condivisa multi-macchina).
AGENT_REGISTRY_GIT_REMOTE=
# Intervallo del loop di sync, secondi.
SYNC_INTERVAL=60

# --- wiki ingest (servizio code) ---
KIMI_API_KEY=

# --- gateway WhatsApp open-wa (servizio wa-gateway) ---
# Immagine del gateway (da finalizzare con le istruzioni docker di OpenWA).
WA_GATEWAY_IMAGE=ghcr.io/rmyndharis/openwa:latest
# API key del gateway open-wa: si GENERA nella dashboard del gateway dopo lo scan QR,
# poi incollala qui (usata dal watchdog nell'header X-API-Key).
WA_API_KEY=
# URL interno del gateway visto dal watchdog.
WA_GATEWAY_URL=http://wa-gateway:2785
# Id della sessione WhatsApp nel gateway.
WA_SESSION_ID=default

# --- notifiche (servizio watchdog) ---
# Destinatario dei messaggi (il TUO numero WhatsApp, formato internazionale, es. 39333...).
WA_RECIPIENT=
# Nome usato nei messaggi al posto di {name}.
WA_NAME=
# Soglia di inattività per l'evento idle, secondi (default 3600 = 1 ora).
IDLE_THRESHOLD=3600
# Intervallo di polling del watchdog, secondi.
WATCHDOG_INTERVAL=60
